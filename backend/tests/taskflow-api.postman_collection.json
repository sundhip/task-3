    "_postman_id": "c0e648c6-5ff8-410a-9d29-c8c160b73c24",
    "name": "TaskFlow API Tests",
    "description": "Postman test suite for verifying TaskFlow API CRUD operations, validation, error paths, and security headers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Tasks (Initial - Empty)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/tasks",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "tasks"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has JSON body\", () => {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test(\"Tasks array exists and is empty\", () => {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "    pm.expect(jsonData.length).to.eql(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Task (Valid)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Learn Node.js & Express\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/tasks",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "tasks"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response is JSON and has task properties\", () => {",
              "    pm.response.to.be.json;",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('text', 'Learn Node.js & Express');",
              "    pm.expect(jsonData).to.have.property('completed', false);",
              "    pm.expect(jsonData).to.have.property('createdAt');",
              "});",
              "",
              "pm.test(\"Security headers are present\", () => {",
              "    pm.response.headers.to.have.header('X-Content-Type-Options', 'nosniff');",
              "    pm.response.headers.to.have.header('X-Frame-Options', 'DENY');",
              "    pm.response.headers.to.have.header('Strict-Transport-Security');",
              "});"
            ]
          }
        }
      ]
    },
